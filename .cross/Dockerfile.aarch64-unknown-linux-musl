FROM ghcr.io/cross-rs/aarch64-unknown-linux-musl:main

ENV DEBIAN_FRONTEND=noninteractive

# Install newer GCC (10+) for C++20 support required by RocksDB
# For aarch64-musl, we need aarch64 cross-compiler with C++20 support
RUN apt-get update && \
    apt-get install -y software-properties-common && \
    add-apt-repository -y ppa:ubuntu-toolchain-r/test && \
    apt-get update && \
    apt-get install -y \
        gcc-10 \
        g++-10 \
        gcc-10-aarch64-linux-gnu \
        g++-10-aarch64-linux-gnu \
        libclang-dev \
        clang \
        llvm \
        lld && \
    # Clean up
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# The cross-rs musl image uses aarch64-unknown-linux-musl- prefix
# We create wrapper scripts that use GCC 10 aarch64 cross-compiler
RUN mkdir -p /usr/local/bin && \
    echo '#!/bin/bash\nexec /usr/bin/aarch64-linux-gnu-gcc-10 "$@"' > /usr/local/bin/aarch64-unknown-linux-musl-gcc && \
    echo '#!/bin/bash\nexec /usr/bin/aarch64-linux-gnu-g++-10 "$@"' > /usr/local/bin/aarch64-unknown-linux-musl-g++ && \
    chmod +x /usr/local/bin/aarch64-unknown-linux-musl-gcc && \
    chmod +x /usr/local/bin/aarch64-unknown-linux-musl-g++

# Ensure /usr/local/bin is first in PATH
ENV PATH="/usr/local/bin:${PATH}"

# Verify the wrapper works
RUN aarch64-unknown-linux-musl-g++ --version
